# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ─────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Next.js Build Output ─────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Testing & Coverage ───────────────────────────────────────────────────────
/coverage
*.lcov

# ─── Environment Variables ────────────────────────────────────────────────────
# Never commit secrets — use .env.example for templates
.env
.env.*
!.env.example

# ─── TypeScript ───────────────────────────────────────────────────────────────
*.tsbuildinfo
next-env.d.ts

# ─── Debug Logs ───────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ─── OS & Editor Artifacts ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.pem

# ─── IDEs & Editors ───────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ─── Deployment ───────────────────────────────────────────────────────────────
.vercel

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.pem
.cache/

AGENTS.md
CLAUDE.md
